pipeline {
    agent any
    environment {
        NAME = "ansh chaudhary"
    }
    parameters {
        string(name: "person", defaultValue: "ansh")
        booleanParam(name: "ismale", defaultValue: true)
        choice(name: "city", choices: ["meerut","skd","baghpat"])
        
    }
    
    stages {
        stage ("test") {
            steps {
                sh """
                ls
                date
                cal 2021
                pwd
                """
               
            }
        }
        stage ("environment variable") {
            steps {
                sh 'echo $BUILD_ID'
                sh 'echo $NAME'
                sh 'echo $ismale'
            }
        }
        stage ("parameter") {
            environment {
                SIRNAME = "chaudhary"
            }
            steps {
                echo "testing on local test server"
                sh 'echo $NAME'
                sh 'echo $person'
            }
        }
        stage ("continue ?") {
            input {
                message "should we continue"
                ok "yes go ahead"
            }
            steps {
                echo "deploy to production"
            }
        }
        stage ("deploy to prod server") {
            steps {
                echo "deploy on prod server"
                sh 'echo $SIRNAME'
            }
        }
    }
    post {
        always {
            echo "hello again"
        }
        failure {
            echo "failure"
        }
        success {
            echo "success"
        }
    }
}
